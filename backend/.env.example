# Personal Access Token from FoxESS cloud (API management / personal center).
# Copy this file to ".env" in this folder and paste your real token.
# Do not commit .env — it is gitignored.
FOXESS_PAT=

# Optional: override the FoxESS API host (defaults to https://www.foxesscloud.com).
# FOXESS_DOMAIN=https://www.foxesscloud.com

# Optional TLS controls (only needed behind a TLS-intercepting corporate proxy):
#   - The backend prefers the OS trust store via the `truststore` package, which
#     normally just works on Windows when the corporate root CA is installed.
#   - Otherwise point FOXESS_CA_BUNDLE at a PEM file containing the corporate
#     root CA(s).
#   - As a last resort set FOXESS_VERIFY_SSL=false (DEV ONLY — never production).
# FOXESS_CA_BUNDLE=C:\path\to\corp-root-ca.pem
# FOXESS_VERIFY_SSL=false
